# PostgreSQL connection string (use Supabase URL in production)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tripmind"

# Long random string for signing JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key"

# Google AI Studio API key — https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key"

# Port for the Express server (optional, defaults to 8000)
PORT=8000
